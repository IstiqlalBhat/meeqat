<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
  <div class="flex gap-8">
    <%- include('partials/sidebar') %>

    <div class="flex-1 max-w-2xl">
      <div class="mb-6">
        <a href="/admin" class="inline-flex items-center gap-1 text-muted text-sm hover:text-charcoal transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Dashboard
        </a>
        <h1 class="text-xl sm:text-2xl font-semibold text-charcoal mt-2">Iqamah Standards</h1>
        <p class="text-muted text-sm mt-1"><%= masjid.name %></p>
      </div>

      <!-- Info box -->
      <div class="bg-sage-400/5 border border-sage-400/20 rounded-xl px-4 py-3 mb-6">
        <p class="text-xs text-sage-600">
          Set rules to auto-calculate iqamah times from daily prayer data. Manual overrides (monthly grid or single-day editor) always take priority over these rules.
        </p>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-cream-200 p-4 sm:p-6">
        <form method="POST" action="/admin/iqamah-standards">
          <div class="space-y-8">
            <% var prayers = ['fajr', 'dhuhr', 'asr', 'maghrib', 'isha']; %>
            <% var prayerLabels = { fajr: 'Fajr', dhuhr: 'Dhuhr', asr: 'Asr', maghrib: 'Maghrib', isha: 'Isha' }; %>
            <% var referenceOptions = [
              { value: 'fajr', label: 'Fajr' },
              { value: 'sunrise', label: 'Sunrise' },
              { value: 'dhuhr', label: 'Dhuhr' },
              { value: 'asr', label: 'Asr' },
              { value: 'sunset', label: 'Sunset' },
              { value: 'maghrib', label: 'Maghrib' },
              { value: 'isha', label: 'Isha' }
            ]; %>

            <% prayers.forEach(function(prayer) { %>
              <%
                var rule = ruleMap[prayer] || null;
                var currentType = rule ? rule.rule_type : 'none';
                var currentValue = rule ? rule.value : '';
                var currentRef = rule ? (rule.reference_prayer || '') : '';
              %>
              <div class="border-b border-cream-100 pb-6 last:border-0 last:pb-0">
                <h3 class="text-sm font-semibold text-charcoal mb-3"><%= prayerLabels[prayer] %></h3>
                <div class="space-y-3">
                  <!-- Radio: None -->
                  <label class="flex items-center gap-3 cursor-pointer group">
                    <input type="radio" name="rule_type_<%= prayer %>" value="none"
                      <%= currentType === 'none' ? 'checked' : '' %>
                      onchange="toggleRuleInputs('<%= prayer %>')"
                      class="w-4 h-4 text-gold-500 border-cream-300 focus:ring-gold-400">
                    <span class="text-sm text-muted group-hover:text-charcoal transition-colors">No rule</span>
                  </label>

                  <!-- Radio: Fixed Time -->
                  <label class="flex items-center gap-3 cursor-pointer group">
                    <input type="radio" name="rule_type_<%= prayer %>" value="fixed"
                      <%= currentType === 'fixed' ? 'checked' : '' %>
                      onchange="toggleRuleInputs('<%= prayer %>')"
                      class="w-4 h-4 text-gold-500 border-cream-300 focus:ring-gold-400">
                    <span class="text-sm text-muted group-hover:text-charcoal transition-colors">Fixed time</span>
                  </label>
                  <div id="input-fixed-<%= prayer %>" class="ml-7 <%= currentType === 'fixed' ? '' : 'hidden' %>">
                    <input type="time" name="value_<%= prayer %>"
                      value="<%= currentType === 'fixed' ? currentValue : '' %>"
                      data-rule-type="fixed"
                      class="px-3 py-2 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 text-sm w-40">
                    <p class="text-xs text-muted mt-1">Iqamah at this exact time every day</p>
                  </div>

                  <!-- Radio: Minutes After Adhan -->
                  <label class="flex items-center gap-3 cursor-pointer group">
                    <input type="radio" name="rule_type_<%= prayer %>" value="after_adhan"
                      <%= currentType === 'after_adhan' ? 'checked' : '' %>
                      onchange="toggleRuleInputs('<%= prayer %>')"
                      class="w-4 h-4 text-gold-500 border-cream-300 focus:ring-gold-400">
                    <span class="text-sm text-muted group-hover:text-charcoal transition-colors">Minutes after adhan</span>
                  </label>
                  <div id="input-after_adhan-<%= prayer %>" class="ml-7 <%= currentType === 'after_adhan' ? '' : 'hidden' %>">
                    <div class="flex items-center gap-2">
                      <input type="number" name="value_<%= prayer %>" min="0" max="120"
                        value="<%= currentType === 'after_adhan' ? currentValue : '' %>"
                        data-rule-type="after_adhan"
                        placeholder="15"
                        class="px-3 py-2 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 text-sm w-24">
                      <span class="text-sm text-muted">minutes after <%= prayerLabels[prayer] %> adhan</span>
                    </div>
                  </div>

                  <!-- Radio: Minutes After Reference -->
                  <label class="flex items-center gap-3 cursor-pointer group">
                    <input type="radio" name="rule_type_<%= prayer %>" value="after_reference"
                      <%= currentType === 'after_reference' ? 'checked' : '' %>
                      onchange="toggleRuleInputs('<%= prayer %>')"
                      class="w-4 h-4 text-gold-500 border-cream-300 focus:ring-gold-400">
                    <span class="text-sm text-muted group-hover:text-charcoal transition-colors">Minutes after reference prayer</span>
                  </label>
                  <div id="input-after_reference-<%= prayer %>" class="ml-7 <%= currentType === 'after_reference' ? '' : 'hidden' %>">
                    <div class="flex flex-wrap items-center gap-2">
                      <input type="number" name="value_<%= prayer %>" min="0" max="120"
                        value="<%= currentType === 'after_reference' ? currentValue : '' %>"
                        data-rule-type="after_reference"
                        placeholder="40"
                        class="px-3 py-2 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 text-sm w-24">
                      <span class="text-sm text-muted">minutes after</span>
                      <select name="reference_<%= prayer %>"
                        class="px-3 py-2 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 text-sm">
                        <% referenceOptions.forEach(function(opt) { %>
                          <option value="<%= opt.value %>" <%= currentRef === opt.value ? 'selected' : '' %>><%= opt.label %></option>
                        <% }) %>
                      </select>
                    </div>
                    <p class="text-xs text-muted mt-1">e.g. Fajr iqamah = 40 min after Sunrise</p>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>

          <div class="flex flex-col sm:flex-row gap-3 mt-8">
            <button type="submit"
              class="flex-1 bg-gradient-to-r from-gold-400 to-gold-500 text-white font-medium py-3 rounded-xl hover:from-gold-500 hover:to-gold-600 transition-all shadow-sm text-sm active:scale-[0.98]">
              Save Iqamah Standards
            </button>
            <a href="/admin" class="px-6 py-3 bg-cream-100 text-muted rounded-xl text-sm font-medium hover:bg-cream-200 transition-colors text-center">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</main>

<script>
function toggleRuleInputs(prayer) {
  var selected = document.querySelector('input[name="rule_type_' + prayer + '"]:checked');
  var type = selected ? selected.value : 'none';
  var types = ['fixed', 'after_adhan', 'after_reference'];

  types.forEach(function(t) {
    var panel = document.getElementById('input-' + t + '-' + prayer);
    if (panel) {
      if (t === type) {
        panel.classList.remove('hidden');
      } else {
        panel.classList.add('hidden');
      }
    }
  });

  // Ensure only the active panel's value input has its name set
  // (prevents stale values from hidden inputs being submitted)
  types.forEach(function(t) {
    var panel = document.getElementById('input-' + t + '-' + prayer);
    if (!panel) return;
    var input = panel.querySelector('input[data-rule-type]');
    if (input) {
      input.name = (t === type) ? 'value_' + prayer : '';
    }
  });
}

// Initialize on load — disable hidden inputs
document.addEventListener('DOMContentLoaded', function() {
  ['fajr', 'dhuhr', 'asr', 'maghrib', 'isha'].forEach(function(prayer) {
    toggleRuleInputs(prayer);
  });
});
</script>
</body>
</html>
