<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-8 gap-4">
    <div>
      <h1 class="text-2xl font-semibold text-charcoal">Dashboard</h1>
      <p class="text-muted text-sm mt-1">Manage your masjids and prayer times</p>
    </div>
    <div class="flex items-center gap-3">
      <span class="text-xs text-muted bg-cream-100 px-3 py-1.5 rounded-lg">
        <span class="inline-block w-2 h-2 bg-sage-400 rounded-full mr-1.5 animate-pulse"></span>
        Connected to Supabase
      </span>
      <a href="/admin/masjids/new" class="bg-sage-400 text-white px-5 py-2.5 rounded-xl text-sm font-medium hover:bg-sage-500 transition-colors shadow-sm inline-flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Add Masjid
      </a>
    </div>
  </div>

  <% if (masjids.length === 0) { %>
    <!-- Empty State -->
    <div class="bg-white rounded-2xl shadow-sm border border-cream-200 p-16 text-center">
      <div class="w-20 h-20 bg-cream-100 rounded-2xl flex items-center justify-center mx-auto mb-5">
        <svg class="w-10 h-10 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
        </svg>
      </div>
      <h3 class="text-xl font-medium text-charcoal mb-2">No masjids yet</h3>
      <p class="text-muted text-sm mb-6 max-w-sm mx-auto">Add your first masjid to start managing prayer times, announcements, and more.</p>
      <a href="/admin/masjids/new" class="inline-flex items-center gap-2 bg-gold-400 text-white px-6 py-3 rounded-xl text-sm font-medium hover:bg-gold-500 transition-colors shadow-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Add Your First Masjid
      </a>
    </div>
  <% } else { %>
    <!-- Stats Overview -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      <div class="bg-white rounded-xl border border-cream-200 p-4">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-gold-400/10 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          </div>
          <div>
            <p class="text-2xl font-semibold text-charcoal"><%= masjids.length %></p>
            <p class="text-xs text-muted">Masjids</p>
          </div>
        </div>
      </div>
      <div class="bg-white rounded-xl border border-cream-200 p-4">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-duck-400/10 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-duck-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <p class="text-2xl font-semibold text-charcoal"><%= masjids.reduce((s, m) => s + m.overrideCount, 0) %></p>
            <p class="text-xs text-muted">Overrides</p>
          </div>
        </div>
      </div>
      <div class="bg-white rounded-xl border border-cream-200 p-4">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-sage-400/10 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-sage-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6"/></svg>
          </div>
          <div>
            <p class="text-2xl font-semibold text-charcoal"><%= masjids.reduce((s, m) => s + m.announcementCount, 0) %></p>
            <p class="text-xs text-muted">Announcements</p>
          </div>
        </div>
      </div>
      <a href="/admin/images" class="bg-white rounded-xl border border-cream-200 p-4 hover:shadow-md transition-all group">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-gold-400/10 rounded-lg flex items-center justify-center group-hover:bg-gold-400/20 transition-colors">
            <svg class="w-5 h-5 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <div>
            <p class="text-2xl font-semibold text-charcoal"><%= imageCount %></p>
            <p class="text-xs text-muted">Images</p>
          </div>
        </div>
      </a>
    </div>

    <!-- Masjid Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      <% masjids.forEach(function(m) { %>
        <div class="bg-white rounded-2xl shadow-sm border border-cream-200 overflow-hidden hover:shadow-md transition-all group">
          <!-- Card Image -->
          <% if (m.image_url) { %>
            <div class="aspect-[16/9] overflow-hidden">
              <img src="<%= m.image_url %>" alt="<%= m.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
            </div>
          <% } else { %>
            <div class="h-2 bg-gradient-to-r from-gold-400 via-sage-400 to-duck-400"></div>
          <% } %>

          <div class="p-5">
            <div class="flex items-start justify-between mb-3">
              <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-charcoal text-lg truncate"><%= m.name %></h3>
                <p class="text-muted text-sm"><%= m.city %>, <%= m.state %></p>
              </div>
              <div class="w-10 h-10 bg-gradient-to-br from-duck-300 to-duck-400 rounded-xl flex items-center justify-center shrink-0 ml-3">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 3L2 12h3v8h14v-8h3L12 3zm0 2.84L18 11v7H6v-7l6-5.16z"/>
                </svg>
              </div>
            </div>

            <% if (m.address) { %>
              <p class="text-xs text-muted mb-3 flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <span class="truncate"><%= m.address %></span>
              </p>
            <% } %>

            <!-- Stats Badges -->
            <div class="flex flex-wrap gap-2 mb-4">
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg bg-cream-50 text-xs text-muted border border-cream-200/50">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <%= m.overrideCount %> overrides
              </span>
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg bg-cream-50 text-xs text-muted border border-cream-200/50">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6"/></svg>
                <%= m.announcementCount %> active
              </span>
              <% if (m.hasJumuah) { %>
                <span class="inline-flex items-center px-2.5 py-1 rounded-lg bg-sage-400/10 text-xs text-sage-500 font-medium border border-sage-400/20">Jumu'ah</span>
              <% } %>
            </div>

            <!-- Action Buttons -->
            <div class="grid grid-cols-4 gap-2">
              <a href="/admin/masjids/<%= m.id %>/timings" class="flex flex-col items-center gap-1 px-2 py-2.5 bg-gold-400/10 text-gold-500 rounded-xl text-xs font-medium hover:bg-gold-400/20 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Timings
              </a>
              <a href="/admin/masjids/<%= m.id %>/jumuah" class="flex flex-col items-center gap-1 px-2 py-2.5 bg-sage-400/10 text-sage-500 rounded-xl text-xs font-medium hover:bg-sage-400/20 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                Jumu'ah
              </a>
              <a href="/admin/masjids/<%= m.id %>/announcements" class="flex flex-col items-center gap-1 px-2 py-2.5 bg-duck-400/10 text-duck-500 rounded-xl text-xs font-medium hover:bg-duck-400/20 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6"/></svg>
                News
              </a>
              <a href="/admin/masjids/<%= m.id %>/edit" class="flex flex-col items-center gap-1 px-2 py-2.5 bg-cream-100 text-muted rounded-xl text-xs font-medium hover:bg-cream-200 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                Edit
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <!-- API Info Bar -->
  <div class="mt-10 bg-white rounded-2xl border border-cream-200 p-5">
    <h3 class="text-sm font-semibold text-charcoal mb-2">Flutter API Endpoints</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs font-mono">
      <div class="bg-cream-50 px-3 py-2 rounded-lg text-muted">GET /api/masjids</div>
      <div class="bg-cream-50 px-3 py-2 rounded-lg text-muted">GET /api/masjids/:id/times?date=YYYY-MM-DD</div>
      <div class="bg-cream-50 px-3 py-2 rounded-lg text-muted">GET /api/masjids/:id/jumuah</div>
      <div class="bg-cream-50 px-3 py-2 rounded-lg text-muted">GET /api/masjids/:id/announcements</div>
    </div>
  </div>
</main>
</body>
</html>
