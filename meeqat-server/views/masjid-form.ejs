<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-8">
    <a href="/admin" class="inline-flex items-center gap-1 text-muted text-sm hover:text-charcoal transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back to Dashboard
    </a>
    <h1 class="text-2xl font-semibold text-charcoal mt-2"><%= masjid && masjid.id ? 'Edit' : 'Add' %> Masjid</h1>
  </div>

  <div class="bg-white rounded-2xl shadow-sm border border-cream-200 p-6">
    <% if (error) { %>
      <div class="flex items-center gap-2 bg-red-50 text-red-600 text-sm rounded-xl px-4 py-3 mb-6 border border-red-100">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <%= error %>
      </div>
    <% } %>

    <form method="POST" action="<%= masjid && masjid.id ? '/admin/masjids/' + masjid.id : '/admin/masjids' %>" enctype="multipart/form-data">
      <div class="space-y-5">
        <!-- Image Upload -->
        <div>
          <label class="block text-sm font-medium text-charcoal mb-1.5">Masjid Photo</label>
          <div class="flex items-start gap-4">
            <% if (masjid && masjid.image_url) { %>
              <div class="w-24 h-24 rounded-xl overflow-hidden border border-cream-200 shrink-0">
                <img src="<%= masjid.image_url %>" alt="Current photo" class="w-full h-full object-cover">
              </div>
            <% } %>
            <div class="flex-1">
              <label class="block w-full cursor-pointer">
                <div class="border-2 border-dashed border-cream-200 rounded-xl p-6 text-center hover:border-gold-400 hover:bg-gold-400/5 transition-all" id="drop-zone">
                  <svg class="w-8 h-8 text-muted mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  <p class="text-sm text-muted">Click to upload or drag & drop</p>
                  <p class="text-xs text-muted mt-1">PNG, JPG up to 20MB</p>
                </div>
                <input type="file" name="image" accept="image/*" class="hidden" onchange="previewFile(this)">
              </label>
              <div id="file-preview" class="hidden mt-2 text-xs text-sage-500 font-medium"></div>
            </div>
          </div>
        </div>

        <div class="h-px bg-cream-200"></div>

        <div>
          <label class="block text-sm font-medium text-charcoal mb-1.5">Masjid Name <span class="text-red-400">*</span></label>
          <input type="text" name="name" required value="<%= masjid ? masjid.name || '' : '' %>"
            class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent text-sm"
            placeholder="e.g., Islamic Center of Clemson">
        </div>

        <div>
          <label class="block text-sm font-medium text-charcoal mb-1.5">Address</label>
          <input type="text" name="address" value="<%= masjid ? masjid.address || '' : '' %>"
            class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent text-sm"
            placeholder="123 Main St">
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-charcoal mb-1.5">City</label>
            <input type="text" name="city" value="<%= masjid ? masjid.city || 'Clemson' : 'Clemson' %>"
              class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent text-sm">
          </div>
          <div>
            <label class="block text-sm font-medium text-charcoal mb-1.5">State</label>
            <input type="text" name="state" value="<%= masjid ? masjid.state || 'South Carolina' : 'South Carolina' %>"
              class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent text-sm">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-charcoal mb-1.5">Country</label>
          <input type="text" name="country" value="<%= masjid ? masjid.country || 'US' : 'US' %>"
            class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent text-sm">
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-charcoal mb-1.5">Latitude</label>
            <input type="number" step="any" name="latitude" value="<%= masjid ? masjid.latitude || '' : '' %>"
              class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent text-sm"
              placeholder="34.6834">
          </div>
          <div>
            <label class="block text-sm font-medium text-charcoal mb-1.5">Longitude</label>
            <input type="number" step="any" name="longitude" value="<%= masjid ? masjid.longitude || '' : '' %>"
              class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent text-sm"
              placeholder="-82.8374">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-charcoal mb-1.5">Calculation Method</label>
          <select name="calculation_method"
            class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent text-sm">
            <option value="2" <%= masjid && masjid.calculation_method == 2 ? 'selected' : '' %>>ISNA (North America)</option>
            <option value="1" <%= masjid && masjid.calculation_method == 1 ? 'selected' : '' %>>MWL (Muslim World League)</option>
            <option value="3" <%= masjid && masjid.calculation_method == 3 ? 'selected' : '' %>>Egyptian General Authority</option>
            <option value="4" <%= masjid && masjid.calculation_method == 4 ? 'selected' : '' %>>Umm Al-Qura University</option>
            <option value="5" <%= masjid && masjid.calculation_method == 5 ? 'selected' : '' %>>University of Islamic Sciences, Karachi</option>
            <option value="0" <%= masjid && masjid.calculation_method == 0 ? 'selected' : '' %>>Shia Ithna-Ashari</option>
          </select>
        </div>
      </div>

      <div class="flex gap-3 mt-8">
        <button type="submit"
          class="flex-1 bg-gradient-to-r from-gold-400 to-gold-500 text-white font-medium py-3 rounded-xl hover:from-gold-500 hover:to-gold-600 transition-all shadow-sm text-sm active:scale-[0.98]">
          <%= masjid && masjid.id ? 'Update' : 'Create' %> Masjid
        </button>
        <a href="/admin" class="px-6 py-3 bg-cream-100 text-muted rounded-xl text-sm font-medium hover:bg-cream-200 transition-colors text-center">Cancel</a>
      </div>
    </form>

    <% if (masjid && masjid.id) { %>
      <div class="mt-8 pt-6 border-t border-cream-200">
        <form method="POST" action="/admin/masjids/<%= masjid.id %>/delete" onsubmit="return confirm('Are you sure you want to delete this masjid? This will also delete all associated timings, jumu\'ah times, and announcements.')">
          <button type="submit" class="flex items-center gap-2 text-red-500 text-sm hover:text-red-600 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            Delete this masjid
          </button>
        </form>
      </div>
    <% } %>
  </div>
</main>

<script>
function previewFile(input) {
  const preview = document.getElementById('file-preview');
  if (input.files && input.files[0]) {
    preview.textContent = 'Selected: ' + input.files[0].name;
    preview.classList.remove('hidden');
  }
}
</script>
</body>
</html>
