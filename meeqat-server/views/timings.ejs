<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
  <div class="flex gap-8">
    <%- include('partials/sidebar') %>

    <div class="flex-1 min-w-0">
      <div class="mb-6">
        <a href="/admin" class="inline-flex items-center gap-1 text-muted text-sm hover:text-charcoal transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Dashboard
        </a>
        <h1 class="text-xl sm:text-2xl font-semibold text-charcoal mt-2">Prayer Times</h1>
        <p class="text-muted text-sm mt-1"><%= masjid.name %></p>
      </div>

      <!-- Date selector -->
      <div class="bg-white rounded-2xl shadow-sm border border-cream-200 p-4 mb-6">
        <form method="GET" action="/admin/timings">
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-4">
            <div class="flex items-center gap-3 flex-wrap">
              <label class="text-sm font-medium text-charcoal">Date:</label>
              <input type="date" name="date" value="<%= date %>"
                class="px-4 py-2 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 text-sm"
                onchange="this.form.submit()">
              <a href="/admin/timings" class="text-sm text-duck-500 hover:text-duck-400 transition-colors font-medium">Today</a>
              <span class="text-cream-300">|</span>
              <a href="/admin/monthly-timings" class="text-sm text-duck-500 hover:text-duck-400 transition-colors font-medium">Monthly Grid</a>
            </div>
            <span class="text-xs text-muted sm:ml-auto">
              Method: <%= ['Shia', 'MWL', 'ISNA', 'Egyptian', 'Umm Al-Qura', 'Karachi'][masjid.calculation_method] || 'Unknown' %>
              &middot; <a href="/admin/api-settings" class="text-duck-500 hover:text-duck-400">Change</a>
            </span>
          </div>
        </form>
      </div>

      <!-- Timings form -->
      <form method="POST" action="/admin/timings" id="timings-form">
        <input type="hidden" name="date" value="<%= date %>">

        <div class="bg-white rounded-2xl shadow-sm border border-cream-200 p-4 mb-6">
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-4">
            <label class="text-sm font-medium text-charcoal">Override Type:</label>
            <div class="flex items-center gap-4">
              <label class="inline-flex items-center gap-2 cursor-pointer">
                <input type="radio" name="override_type" value="date" checked class="w-4 h-4 text-gold-400 border-cream-300 focus:ring-gold-400">
                <span class="text-sm text-muted">Date-specific (<%= date %>)</span>
              </label>
              <label class="inline-flex items-center gap-2 cursor-pointer">
                <input type="radio" name="override_type" value="permanent" class="w-4 h-4 text-gold-400 border-cream-300 focus:ring-gold-400">
                <span class="text-sm text-muted">Permanent</span>
              </label>
            </div>
          </div>
        </div>

        <!-- Help text -->
        <div class="bg-duck-400/5 border border-duck-400/20 rounded-xl px-4 py-3 mb-6">
          <p class="text-xs text-duck-600">
            <strong>Use API:</strong> Check this to remove any override and use the calculated API time for that prayer. Unchecking it won't change anything unless you also enter a time.
          </p>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-cream-200 overflow-hidden">
          <!-- Desktop table -->
          <div class="hidden md:block overflow-x-auto" id="desktop-section">
            <table class="w-full">
              <thead>
                <tr class="border-b border-cream-200 bg-cream-50/50">
                  <th class="text-left px-4 lg:px-5 py-3.5 text-xs font-semibold text-muted uppercase tracking-wider">Prayer</th>
                  <th class="text-left px-4 lg:px-5 py-3.5 text-xs font-semibold text-muted uppercase tracking-wider">API Time</th>
                  <th class="text-left px-4 lg:px-5 py-3.5 text-xs font-semibold text-muted uppercase tracking-wider">Athan Override</th>
                  <th class="text-left px-4 lg:px-5 py-3.5 text-xs font-semibold text-muted uppercase tracking-wider">Iqamah</th>
                  <th class="text-center px-4 lg:px-5 py-3.5 text-xs font-semibold text-muted uppercase tracking-wider">Use API</th>
                </tr>
              </thead>
              <tbody>
                <% prayers.forEach(function(prayer, i) { %>
                  <% var override = overrideMap[prayer]; %>
                  <% var prayerLabel = prayer.charAt(0).toUpperCase() + prayer.slice(1); %>
                  <% var isNonIqamah = (prayer === 'sunrise' || prayer === 'sunset'); %>
                  <% var hasOverride = !!override; %>
                  <tr class="<%= i % 2 === 0 ? 'bg-white' : 'bg-cream-50/30' %> border-b border-cream-100 last:border-0 hover:bg-cream-50/50 transition-colors" id="row-<%= prayer %>">
                    <td class="px-4 lg:px-5 py-4">
                      <div class="flex items-center gap-2">
                        <span class="text-sm font-medium text-charcoal"><%= prayerLabel %></span>
                        <% if (override) { %>
                          <span class="text-[10px] px-2 py-0.5 rounded-full font-medium
                            <%= override.type === 'permanent' ? 'bg-duck-400/10 text-duck-500' : 'bg-gold-300/20 text-gold-500' %>">
                            <%= override.type %>
                          </span>
                        <% } else { %>
                          <span class="text-[10px] px-2 py-0.5 rounded-full bg-sage-400/10 text-sage-500 font-medium">api</span>
                        <% } %>
                      </div>
                    </td>
                    <td class="px-4 lg:px-5 py-4">
                      <span class="text-sm text-muted font-mono bg-cream-50 px-2 py-1 rounded"><%= apiTimes[prayer] || '--:--' %></span>
                    </td>
                    <td class="px-4 lg:px-5 py-4">
                      <input type="time" name="athan_<%= prayer %>"
                        value="<%= override && override.athan_time ? override.athan_time : '' %>"
                        class="px-3 py-2 rounded-lg border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 text-sm w-28 lg:w-32"
                        onchange="document.getElementById('useapi-<%= prayer %>').checked = false; updateRowOpacity('<%= prayer %>')">
                    </td>
                    <td class="px-4 lg:px-5 py-4">
                      <% if (!isNonIqamah) { %>
                        <input type="time" name="iqamah_<%= prayer %>"
                          value="<%= override && override.iqamah_time ? override.iqamah_time : '' %>"
                          class="px-3 py-2 rounded-lg border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-sage-400 text-sm w-28 lg:w-32"
                          onchange="document.getElementById('useapi-<%= prayer %>').checked = false; updateRowOpacity('<%= prayer %>')">
                      <% } else { %>
                        <span class="text-xs text-muted italic">N/A</span>
                      <% } %>
                    </td>
                    <td class="px-4 lg:px-5 py-4 text-center">
                      <label class="inline-flex items-center justify-center cursor-pointer">
                        <input type="checkbox" id="useapi-<%= prayer %>" name="useapi_<%= prayer %>" value="1"
                          <%= !hasOverride ? 'checked' : '' %>
                          class="w-4 h-4 rounded border-cream-300 text-duck-400 focus:ring-duck-400 cursor-pointer"
                          onchange="handleUseApi(this, '<%= prayer %>')">
                      </label>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <!-- Mobile cards -->
          <div class="md:hidden divide-y divide-cream-100" id="mobile-section">
            <% prayers.forEach(function(prayer) { %>
              <% var override = overrideMap[prayer]; %>
              <% var prayerLabel = prayer.charAt(0).toUpperCase() + prayer.slice(1); %>
              <% var isNonIqamah = (prayer === 'sunrise' || prayer === 'sunset'); %>
              <% var hasOverride = !!override; %>
              <div class="p-4 space-y-3">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-2">
                    <span class="font-medium text-charcoal"><%= prayerLabel %></span>
                    <span class="text-[10px] px-2 py-0.5 rounded-full font-mono
                      <% if (override) { %>
                        <%= override.type === 'permanent' ? 'bg-duck-400/10 text-duck-500' : 'bg-gold-300/20 text-gold-500' %>
                      <% } else { %>
                        bg-cream-100 text-muted
                      <% } %>
                    "><%= override ? override.type : apiTimes[prayer] || '--:--' %></span>
                  </div>
                  <label class="inline-flex items-center gap-1.5 text-xs text-muted cursor-pointer">
                    <input type="checkbox" name="useapi_<%= prayer %>" value="1"
                      <%= !hasOverride ? 'checked' : '' %>
                      class="w-3.5 h-3.5 rounded border-cream-300 text-duck-400 focus:ring-duck-400"
                      onchange="handleUseApiMobile(this, '<%= prayer %>')">
                    API
                  </label>
                </div>
                <div class="grid grid-cols-2 gap-3">
                  <div>
                    <label class="text-[10px] text-muted uppercase tracking-wider block mb-1">Athan</label>
                    <input type="time" name="athan_<%= prayer %>"
                      value="<%= override && override.athan_time ? override.athan_time : '' %>"
                      class="w-full px-3 py-2.5 rounded-lg border border-cream-200 bg-cream-50 text-charcoal text-sm">
                  </div>
                  <div>
                    <label class="text-[10px] text-muted uppercase tracking-wider block mb-1">Iqamah</label>
                    <% if (!isNonIqamah) { %>
                      <input type="time" name="iqamah_<%= prayer %>"
                        value="<%= override && override.iqamah_time ? override.iqamah_time : '' %>"
                        class="w-full px-3 py-2.5 rounded-lg border border-cream-200 bg-cream-50 text-charcoal text-sm">
                    <% } else { %>
                      <p class="px-3 py-2.5 text-xs text-muted italic">N/A</p>
                    <% } %>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="mt-6 flex flex-col sm:flex-row gap-3">
          <button type="submit"
            class="bg-gradient-to-r from-gold-400 to-gold-500 text-white font-medium px-8 py-3 rounded-xl hover:from-gold-500 hover:to-gold-600 transition-all shadow-sm text-sm active:scale-[0.98] w-full sm:w-auto">
            Save Timings
          </button>
          <a href="/admin" class="px-6 py-3 bg-cream-100 text-muted rounded-xl text-sm font-medium hover:bg-cream-200 transition-colors text-center">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</main>

<script>
// On form submit, disable all inputs in the hidden section so duplicate names don't conflict
document.getElementById('timings-form').addEventListener('submit', function() {
  var isMobile = window.innerWidth < 768;
  var sectionToDisable = isMobile
    ? document.getElementById('desktop-section')
    : document.getElementById('mobile-section');

  sectionToDisable.querySelectorAll('input').forEach(function(input) {
    input.disabled = true;
  });
});

function handleUseApi(checkbox, prayer) {
  if (checkbox.checked) {
    var row = document.getElementById('row-' + prayer);
    var athanInput = row.querySelector('input[name="athan_' + prayer + '"]');
    var iqamahInput = row.querySelector('input[name="iqamah_' + prayer + '"]');
    if (athanInput) athanInput.value = '';
    if (iqamahInput) iqamahInput.value = '';
  }
  updateRowOpacity(prayer);
}

function handleUseApiMobile(checkbox, prayer) {
  if (checkbox.checked) {
    var section = document.getElementById('mobile-section');
    var athanInput = section.querySelector('input[name="athan_' + prayer + '"]');
    var iqamahInput = section.querySelector('input[name="iqamah_' + prayer + '"]');
    if (athanInput) athanInput.value = '';
    if (iqamahInput) iqamahInput.value = '';
  }
}

function updateRowOpacity(prayer) {
  var checkbox = document.getElementById('useapi-' + prayer);
  var row = document.getElementById('row-' + prayer);
  if (row && checkbox) {
    row.style.opacity = checkbox.checked ? '0.5' : '1';
  }
}

// Initialize row opacity on page load
document.addEventListener('DOMContentLoaded', function() {
  <% prayers.forEach(function(prayer) { %>
    updateRowOpacity('<%= prayer %>');
  <% }) %>
});
</script>
</body>
</html>
