<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
  <div class="flex gap-8">
    <%- include('partials/sidebar') %>

    <div class="flex-1 max-w-xl">
      <div class="mb-6">
        <a href="/admin" class="inline-flex items-center gap-1 text-muted text-sm hover:text-charcoal transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Dashboard
        </a>
        <h1 class="text-xl sm:text-2xl font-semibold text-charcoal mt-2">API Settings</h1>
        <p class="text-muted text-sm mt-1">Configure location and calculation method for prayer times</p>
      </div>

      <!-- Info box -->
      <div class="bg-duck-400/5 border border-duck-400/20 rounded-xl px-4 py-3 mb-6">
        <p class="text-xs text-duck-600">
          Prayer times are fetched from the <strong>Aladhan API</strong> using the coordinates and calculation method below. Change these to get accurate times for your masjid's location.
        </p>
      </div>

      <% if (error) { %>
        <div class="flex items-center gap-2 bg-red-50 text-red-600 text-sm rounded-xl px-4 py-3 mb-6 border border-red-100">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <%= error %>
        </div>
      <% } %>

      <!-- Location Search -->
      <div class="bg-white rounded-2xl shadow-sm border border-cream-200 p-4 sm:p-6 mb-6">
        <h3 class="text-sm font-semibold text-charcoal mb-4 flex items-center gap-2">
          <svg class="w-4 h-4 text-duck-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          Search Location
        </h3>
        <div class="flex flex-col sm:flex-row gap-3">
          <input type="text" id="location-search" placeholder="e.g., Mecca, Saudi Arabia"
            class="flex-1 px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-duck-400 text-sm"
            onkeydown="if(event.key==='Enter'){event.preventDefault(); searchLocation();}">
          <button type="button" onclick="searchLocation()"
            class="px-5 py-3 bg-duck-400 text-white rounded-xl text-sm font-medium hover:bg-duck-500 transition-colors shrink-0 w-full sm:w-auto">
            Search
          </button>
        </div>
        <div id="search-results" class="hidden mt-3 space-y-2"></div>
        <div id="search-error" class="hidden mt-3 text-xs text-red-500"></div>
      </div>

      <!-- Settings Form -->
      <div class="bg-white rounded-2xl shadow-sm border border-cream-200 p-4 sm:p-6">
        <form method="POST" action="/admin/api-settings">
          <div class="space-y-5">
            <!-- Current location display -->
            <div class="bg-cream-50 rounded-xl p-4 border border-cream-200/50">
              <p class="text-xs text-muted uppercase tracking-wider font-medium mb-2">Current Location</p>
              <p class="text-sm font-medium text-charcoal" id="current-location">
                <% if (masjid.latitude && masjid.longitude) { %>
                  <%= masjid.latitude.toFixed(4) %>, <%= masjid.longitude.toFixed(4) %>
                <% } else { %>
                  Not set
                <% } %>
              </p>
            </div>

            <div class="grid grid-cols-2 gap-3 sm:gap-4">
              <div>
                <label class="block text-sm font-medium text-charcoal mb-1.5">Latitude</label>
                <input type="number" step="any" name="latitude" id="lat-input"
                  value="<%= masjid.latitude || '' %>"
                  class="w-full px-3 sm:px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 text-sm"
                  placeholder="34.6834">
              </div>
              <div>
                <label class="block text-sm font-medium text-charcoal mb-1.5">Longitude</label>
                <input type="number" step="any" name="longitude" id="lng-input"
                  value="<%= masjid.longitude || '' %>"
                  class="w-full px-3 sm:px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 text-sm"
                  placeholder="-82.8374">
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-charcoal mb-1.5">Calculation Method</label>
              <select name="calculation_method"
                class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 text-sm">
                <option value="2" <%= masjid.calculation_method == 2 ? 'selected' : '' %>>ISNA (North America)</option>
                <option value="1" <%= masjid.calculation_method == 1 ? 'selected' : '' %>>MWL (Muslim World League)</option>
                <option value="3" <%= masjid.calculation_method == 3 ? 'selected' : '' %>>Egyptian General Authority</option>
                <option value="4" <%= masjid.calculation_method == 4 ? 'selected' : '' %>>Umm Al-Qura University (Makkah)</option>
                <option value="5" <%= masjid.calculation_method == 5 ? 'selected' : '' %>>University of Islamic Sciences, Karachi</option>
                <option value="7" <%= masjid.calculation_method == 7 ? 'selected' : '' %>>Institute of Geophysics, Tehran</option>
                <option value="8" <%= masjid.calculation_method == 8 ? 'selected' : '' %>>Gulf Region</option>
                <option value="9" <%= masjid.calculation_method == 9 ? 'selected' : '' %>>Kuwait</option>
                <option value="10" <%= masjid.calculation_method == 10 ? 'selected' : '' %>>Qatar</option>
                <option value="11" <%= masjid.calculation_method == 11 ? 'selected' : '' %>>Majlis Ugama Islam Singapura</option>
                <option value="12" <%= masjid.calculation_method == 12 ? 'selected' : '' %>>UOIF (France)</option>
                <option value="13" <%= masjid.calculation_method == 13 ? 'selected' : '' %>>DIYANET (Turkey)</option>
                <option value="14" <%= masjid.calculation_method == 14 ? 'selected' : '' %>>Spiritual Administration of Muslims of Russia</option>
                <option value="15" <%= masjid.calculation_method == 15 ? 'selected' : '' %>>Moonsighting Committee Worldwide</option>
                <option value="0" <%= masjid.calculation_method == 0 ? 'selected' : '' %>>Shia Ithna-Ashari</option>
              </select>
              <p class="text-xs text-muted mt-1.5">Different methods use different Fajr and Isha angles. Choose the one commonly used in your region.</p>
            </div>

            <!-- Preview -->
            <div id="preview-section" class="hidden">
              <div class="h-px bg-cream-200 my-2"></div>
              <p class="text-xs text-muted uppercase tracking-wider font-medium mb-3">Preview (Today's Times)</p>
              <div id="preview-times" class="grid grid-cols-3 sm:grid-cols-6 gap-2"></div>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-3 mt-8">
            <button type="submit"
              class="flex-1 bg-gradient-to-r from-gold-400 to-gold-500 text-white font-medium py-3 rounded-xl hover:from-gold-500 hover:to-gold-600 transition-all shadow-sm text-sm active:scale-[0.98]">
              Save API Settings
            </button>
            <button type="button" onclick="previewTimes()"
              class="px-5 py-3 bg-cream-100 text-muted rounded-xl text-sm font-medium hover:bg-cream-200 transition-colors">
              Preview Times
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</main>

<script>
async function searchLocation() {
  var query = document.getElementById('location-search').value.trim();
  if (!query) return;

  var resultsDiv = document.getElementById('search-results');
  var errorDiv = document.getElementById('search-error');
  resultsDiv.classList.add('hidden');
  errorDiv.classList.add('hidden');
  resultsDiv.innerHTML = '<p class="text-xs text-muted">Searching...</p>';
  resultsDiv.classList.remove('hidden');

  try {
    var res = await fetch('https://nominatim.openstreetmap.org/search?format=json&limit=5&q=' + encodeURIComponent(query), {
      headers: { 'User-Agent': 'MeeqatAdmin/1.0' }
    });
    var data = await res.json();

    if (!data.length) {
      resultsDiv.innerHTML = '<p class="text-xs text-muted">No results found. Try a different search term.</p>';
      return;
    }

    resultsDiv.innerHTML = '';
    data.forEach(function(place) {
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'w-full text-left px-4 py-3 rounded-xl border border-cream-200 hover:border-duck-400 hover:bg-duck-400/5 transition-all text-sm';
      btn.innerHTML = '<p class="font-medium text-charcoal">' + escapeHtml(place.display_name.split(',').slice(0, 3).join(',')) + '</p>'
        + '<p class="text-xs text-muted mt-0.5">' + parseFloat(place.lat).toFixed(4) + ', ' + parseFloat(place.lon).toFixed(4) + '</p>';
      btn.onclick = function() {
        document.getElementById('lat-input').value = parseFloat(place.lat).toFixed(6);
        document.getElementById('lng-input').value = parseFloat(place.lon).toFixed(6);
        document.getElementById('current-location').textContent = parseFloat(place.lat).toFixed(4) + ', ' + parseFloat(place.lon).toFixed(4) + ' (' + place.display_name.split(',')[0] + ')';
        resultsDiv.classList.add('hidden');
      };
      resultsDiv.appendChild(btn);
    });
  } catch (err) {
    errorDiv.textContent = 'Search failed: ' + err.message;
    errorDiv.classList.remove('hidden');
    resultsDiv.classList.add('hidden');
  }
}

async function previewTimes() {
  var lat = document.getElementById('lat-input').value;
  var lng = document.getElementById('lng-input').value;
  var method = document.querySelector('select[name="calculation_method"]').value;

  if (!lat || !lng) {
    alert('Enter latitude and longitude first.');
    return;
  }

  var previewSection = document.getElementById('preview-section');
  var previewTimesEl = document.getElementById('preview-times');
  previewTimesEl.innerHTML = '<p class="col-span-full text-xs text-muted">Loading...</p>';
  previewSection.classList.remove('hidden');

  try {
    var today = new Date();
    var dd = String(today.getDate()).padStart(2, '0');
    var mm = String(today.getMonth() + 1).padStart(2, '0');
    var yyyy = today.getFullYear();

    var res = await fetch('https://api.aladhan.com/v1/timings/' + dd + '-' + mm + '-' + yyyy + '?latitude=' + lat + '&longitude=' + lng + '&method=' + method);
    var data = await res.json();

    if (data.code === 200) {
      var t = data.data.timings;
      var prayers = [
        { name: 'Fajr', time: t.Fajr, color: 'duck' },
        { name: 'Sunrise', time: t.Sunrise, color: 'gold' },
        { name: 'Dhuhr', time: t.Dhuhr, color: 'sage' },
        { name: 'Asr', time: t.Asr, color: 'gold' },
        { name: 'Maghrib', time: t.Maghrib, color: 'duck' },
        { name: 'Isha', time: t.Isha, color: 'sage' }
      ];

      previewTimesEl.innerHTML = prayers.map(function(p) {
        return '<div class="bg-' + p.color + '-400/10 rounded-lg px-3 py-2 text-center">'
          + '<p class="text-[10px] text-muted uppercase tracking-wider">' + p.name + '</p>'
          + '<p class="text-sm font-semibold text-charcoal mt-0.5">' + p.time + '</p>'
          + '</div>';
      }).join('');
    } else {
      previewTimesEl.innerHTML = '<p class="col-span-full text-xs text-red-500">Failed to fetch times. Check coordinates.</p>';
    }
  } catch (err) {
    previewTimesEl.innerHTML = '<p class="col-span-full text-xs text-red-500">Error: ' + err.message + '</p>';
  }
}

function escapeHtml(str) {
  var div = document.createElement('div');
  div.textContent = str;
  return div.innerHTML;
}
</script>
</body>
</html>
