<%- include('partials/head') %>

<header class="bg-white/80 backdrop-blur-md border-b border-cream-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-gradient-to-br from-gold-400 to-gold-500 rounded-xl flex items-center justify-center shadow-sm">
          <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 2L3 7v11h14V7l-7-5zm0 2.236L15 8v8H5V8l5-3.764z"/>
          </svg>
        </div>
        <span class="text-lg font-semibold text-charcoal tracking-tight">Meeqat</span>
      </div>
      <a href="/admin/logout" class="text-muted hover:text-charcoal transition-colors text-sm px-3 py-2 rounded-lg hover:bg-cream-100">Logout</a>
    </div>
  </div>
</header>

<main class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
  <div class="text-center mb-6 sm:mb-8">
    <div class="w-14 h-14 sm:w-16 sm:h-16 bg-gradient-to-br from-sage-400 to-sage-500 rounded-2xl flex items-center justify-center shadow-lg mx-auto mb-4 sm:mb-5">
      <svg class="w-7 h-7 sm:w-8 sm:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
      </svg>
    </div>
    <h1 class="text-xl sm:text-2xl font-semibold text-charcoal">Welcome to Meeqat!</h1>
    <p class="text-muted text-sm mt-2 max-w-md mx-auto">Let's set up your masjid. You can always update these details later.</p>
  </div>

  <div class="bg-white rounded-2xl shadow-sm border border-cream-200 p-4 sm:p-6">
    <% if (error) { %>
      <div class="flex items-center gap-2 bg-red-50 text-red-600 text-sm rounded-xl px-4 py-3 mb-6 border border-red-100">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <%= error %>
      </div>
    <% } %>

    <form method="POST" action="/admin/setup" enctype="multipart/form-data">
      <div class="space-y-5">
        <!-- Image Upload -->
        <div>
          <label class="block text-sm font-medium text-charcoal mb-1.5">Masjid Photo <span class="text-muted font-normal">(optional)</span></label>
          <label class="block cursor-pointer">
            <div class="border-2 border-dashed border-cream-200 rounded-xl p-4 sm:p-6 text-center hover:border-gold-400 hover:bg-gold-400/5 transition-all">
              <svg class="w-8 h-8 text-muted mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              <p class="text-sm text-muted">Click to upload or drag & drop</p>
              <p class="text-xs text-muted mt-1">PNG, JPG up to 4MB</p>
            </div>
            <input type="file" name="image" accept="image/*" class="hidden" onchange="previewFile(this)">
          </label>
          <div id="file-preview" class="hidden mt-2 text-xs text-sage-500 font-medium"></div>
        </div>

        <div class="h-px bg-cream-200"></div>

        <div>
          <label class="block text-sm font-medium text-charcoal mb-1.5">Masjid Name <span class="text-red-400">*</span></label>
          <input type="text" name="name" required
            class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent text-sm"
            placeholder="e.g., Islamic Center of Clemson">
        </div>

        <div>
          <label class="block text-sm font-medium text-charcoal mb-1.5">Address</label>
          <input type="text" name="address"
            class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent text-sm"
            placeholder="123 Main St">
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-charcoal mb-1.5">City</label>
            <input type="text" name="city" value="Clemson"
              class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent text-sm">
          </div>
          <div>
            <label class="block text-sm font-medium text-charcoal mb-1.5">State</label>
            <input type="text" name="state" value="South Carolina"
              class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent text-sm">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-charcoal mb-1.5">Country</label>
          <input type="text" name="country" value="US"
            class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent text-sm">
        </div>

        <div class="grid grid-cols-2 gap-3 sm:gap-4">
          <div>
            <label class="block text-sm font-medium text-charcoal mb-1.5">Latitude</label>
            <input type="number" step="any" name="latitude"
              class="w-full px-3 sm:px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent text-sm"
              placeholder="34.6834">
          </div>
          <div>
            <label class="block text-sm font-medium text-charcoal mb-1.5">Longitude</label>
            <input type="number" step="any" name="longitude"
              class="w-full px-3 sm:px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent text-sm"
              placeholder="-82.8374">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-charcoal mb-1.5">Calculation Method</label>
          <select name="calculation_method"
            class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent text-sm">
            <option value="2" selected>ISNA (North America)</option>
            <option value="1">MWL (Muslim World League)</option>
            <option value="3">Egyptian General Authority</option>
            <option value="4">Umm Al-Qura University</option>
            <option value="5">University of Islamic Sciences, Karachi</option>
            <option value="0">Shia Ithna-Ashari</option>
          </select>
        </div>
      </div>

      <button type="submit"
        class="w-full mt-8 bg-gradient-to-r from-sage-400 to-sage-500 text-white font-medium py-3.5 rounded-xl hover:from-sage-500 hover:to-sage-600 transition-all shadow-sm text-sm active:scale-[0.98]">
        Create My Masjid
      </button>
    </form>
  </div>
</main>

<script src="/js/image-compress.js"></script>
<script>
function previewFile(input) {
  var preview = document.getElementById('file-preview');
  if (input.files && input.files[0]) {
    preview.textContent = 'Selected: ' + input.files[0].name;
    preview.classList.remove('hidden');
  }
}
document.addEventListener('DOMContentLoaded', () => {
  setupImageCompression(document.querySelector('form[action="/admin/setup"]'));
});
</script>
</body>
</html>
