<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meeqat Admin - Login</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            cream: { 50: '#FAF6F0', 100: '#F5EDE3', 200: '#EDE0D0' },
            gold: { 300: '#E8C9A0', 400: '#D4A574', 500: '#C9956B', 600: '#B8804F' },
            sage: { 300: '#A7C4A0', 400: '#8FAE8B', 500: '#6B8F71' },
            duck: { 300: '#B5CDD3', 400: '#8EADB5', 500: '#6D9BA3' },
            charcoal: '#2C2C2E',
            muted: '#6B5E50'
          },
          fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] }
        }
      }
    }
  </script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-cream-50 text-charcoal font-sans min-h-screen">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-sm">
      <div class="text-center mb-8">
        <div class="w-20 h-20 bg-gradient-to-br from-gold-400 to-gold-500 rounded-2xl flex items-center justify-center shadow-lg mx-auto mb-5 login-logo">
          <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 3L2 12h3v8h14v-8h3L12 3zm0 2.84L18 11v7H6v-7l6-5.16z"/>
          </svg>
        </div>
        <h1 class="text-2xl font-semibold text-charcoal">Meeqat Admin</h1>
        <p class="text-muted text-sm mt-1">Prayer times management dashboard</p>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-cream-200 p-6">
        <div id="error-box" class="hidden flex items-center gap-2 bg-red-50 text-red-600 text-sm rounded-xl px-4 py-3 mb-4 border border-red-100">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span id="error-text"></span>
        </div>

        <% if (error) { %>
          <div class="flex items-center gap-2 bg-red-50 text-red-600 text-sm rounded-xl px-4 py-3 mb-4 border border-red-100">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <%= error %>
          </div>
        <% } %>

        <!-- Toggle: Sign In / Register -->
        <div class="flex bg-cream-100 rounded-xl p-1 mb-5 gap-0.5">
          <button type="button" id="tab-login" onclick="toggleMode('login')"
            class="flex-1 text-sm font-medium py-2 rounded-lg transition-colors bg-white text-charcoal shadow-sm">
            Sign In
          </button>
          <button type="button" id="tab-register" onclick="toggleMode('register')"
            class="flex-1 text-sm font-medium py-2 rounded-lg transition-colors text-muted hover:text-charcoal">
            Register
          </button>
        </div>

        <form id="auth-form" onsubmit="handleAuth(event)">
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-muted mb-2">Email</label>
              <input type="email" id="email" required autofocus
                class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent transition-all text-sm"
                placeholder="admin@yourmasjid.org">
            </div>

            <div>
              <label class="block text-sm font-medium text-muted mb-2">Password</label>
              <input type="password" id="password" required minlength="6"
                class="w-full px-4 py-3 rounded-xl border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent transition-all text-sm"
                placeholder="Enter password">
            </div>
          </div>

          <button type="submit" id="submit-btn"
            class="w-full mt-5 bg-gradient-to-r from-gold-400 to-gold-500 text-white font-medium py-3 rounded-xl hover:from-gold-500 hover:to-gold-600 transition-all shadow-sm text-sm active:scale-[0.98] disabled:opacity-60"
            disabled>
            Sign In
          </button>
        </form>
      </div>

      <p class="text-center text-xs text-muted mt-4">Secured with Firebase Authentication</p>
    </div>
  </div>

  <!-- Firebase JS SDK -->
  <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-auth-compat.js"></script>
  <script>
    const firebaseConfig = {
      apiKey: '<%= firebaseApiKey %>',
      authDomain: '<%= firebaseAuthDomain %>'
    };

    let app, authInstance;
    let mode = 'login';

    try {
      app = firebase.initializeApp(firebaseConfig);
      authInstance = firebase.auth();
      document.getElementById('submit-btn').disabled = false;
    } catch (err) {
      showError('Firebase initialization failed. Check your configuration.');
    }

    function toggleMode(newMode) {
      mode = newMode;
      const loginTab = document.getElementById('tab-login');
      const registerTab = document.getElementById('tab-register');
      const btn = document.getElementById('submit-btn');

      if (mode === 'login') {
        loginTab.className = 'flex-1 text-sm font-medium py-2 rounded-lg transition-colors bg-white text-charcoal shadow-sm';
        registerTab.className = 'flex-1 text-sm font-medium py-2 rounded-lg transition-colors text-muted hover:text-charcoal';
        btn.textContent = 'Sign In';
      } else {
        registerTab.className = 'flex-1 text-sm font-medium py-2 rounded-lg transition-colors bg-white text-charcoal shadow-sm';
        loginTab.className = 'flex-1 text-sm font-medium py-2 rounded-lg transition-colors text-muted hover:text-charcoal';
        btn.textContent = 'Create Account';
      }

      hideError();
    }

    function showError(msg) {
      const box = document.getElementById('error-box');
      document.getElementById('error-text').textContent = msg;
      box.classList.remove('hidden');
      box.classList.add('flex');
    }

    function hideError() {
      const box = document.getElementById('error-box');
      box.classList.add('hidden');
      box.classList.remove('flex');
    }

    async function handleAuth(e) {
      e.preventDefault();
      hideError();

      const email = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value;
      const btn = document.getElementById('submit-btn');

      btn.disabled = true;
      btn.textContent = mode === 'login' ? 'Signing in...' : 'Creating account...';

      try {
        let userCredential;
        if (mode === 'register') {
          userCredential = await authInstance.createUserWithEmailAndPassword(email, password);
        } else {
          userCredential = await authInstance.signInWithEmailAndPassword(email, password);
        }

        const idToken = await userCredential.user.getIdToken();

        const res = await fetch('/admin/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ idToken })
        });

        const data = await res.json();
        if (data.ok) {
          window.location.href = '/admin';
        } else {
          showError(data.error || 'Authentication failed');
          btn.disabled = false;
          btn.textContent = mode === 'login' ? 'Sign In' : 'Create Account';
        }
      } catch (err) {
        let msg = 'Authentication failed';
        if (err.code === 'auth/user-not-found') msg = 'No account found with this email';
        else if (err.code === 'auth/wrong-password') msg = 'Incorrect password';
        else if (err.code === 'auth/invalid-credential') msg = 'Invalid email or password';
        else if (err.code === 'auth/email-already-in-use') msg = 'An account with this email already exists';
        else if (err.code === 'auth/weak-password') msg = 'Password must be at least 6 characters';
        else if (err.code === 'auth/invalid-email') msg = 'Please enter a valid email address';
        else if (err.message) msg = err.message;

        showError(msg);
        btn.disabled = false;
        btn.textContent = mode === 'login' ? 'Sign In' : 'Create Account';
      }
    }
  </script>
</body>
</html>
