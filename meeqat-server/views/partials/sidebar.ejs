    <div class="h-px bg-cream-200 mb-2"></div>
    <nav class="space-y-0.5">
      <a href="/admin/edit" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-muted hover:text-charcoal hover:bg-cream-50 transition-all">
