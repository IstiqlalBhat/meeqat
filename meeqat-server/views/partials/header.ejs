<header class="bg-white/80 backdrop-blur-md border-b border-cream-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <div class="flex items-center gap-3">
        <!-- Mobile hamburger -->
        <button type="button" id="mobile-menu-btn" onclick="toggleMobileMenu()" class="lg:hidden -ml-1 p-2 rounded-xl text-muted hover:text-charcoal hover:bg-cream-100 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <a href="/admin" class="flex items-center gap-3 group">
          <div class="w-9 h-9 bg-gradient-to-br from-gold-400 to-gold-500 rounded-xl flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 2L3 7v11h14V7l-7-5zm0 2.236L15 8v8H5V8l5-3.764z"/>
            </svg>
          </div>
          <div>
            <span class="text-lg font-semibold text-charcoal tracking-tight">Meeqat</span>
            <span class="hidden sm:inline text-xs text-muted ml-1.5 font-normal">Admin</span>
          </div>
        </a>
      </div>
      <nav class="flex items-center gap-2 sm:gap-4">
        <a href="/admin" class="hidden sm:inline-flex text-muted hover:text-charcoal transition-colors text-sm font-medium px-3 py-2 rounded-lg hover:bg-cream-100">Dashboard</a>
        <% if (typeof adminEmail !== 'undefined' && adminEmail) { %>
          <span class="hidden md:inline text-xs text-muted bg-cream-100 px-3 py-1.5 rounded-lg truncate max-w-[180px]"><%= adminEmail %></span>
        <% } %>
        <a href="/admin/logout" class="text-muted hover:text-charcoal transition-colors text-sm px-3 py-2 rounded-lg hover:bg-cream-100">
          <span class="hidden sm:inline">Logout</span>
          <svg class="w-4 h-4 sm:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        </a>
      </nav>
    </div>
  </div>
</header>

<!-- Mobile navigation drawer -->
<div id="mobile-menu-overlay" class="fixed inset-0 z-[60] hidden" onclick="closeMobileMenu()">
  <div class="absolute inset-0 bg-black/30 backdrop-blur-sm"></div>
</div>
<aside id="mobile-menu-drawer" class="fixed top-0 left-0 bottom-0 z-[70] w-72 bg-white shadow-2xl transform -translate-x-full transition-transform duration-300 ease-in-out lg:hidden">
  <div class="flex flex-col h-full">
    <!-- Drawer header -->
    <div class="flex items-center justify-between px-5 h-16 border-b border-cream-200 shrink-0">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-gradient-to-br from-gold-400 to-gold-500 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 2L3 7v11h14V7l-7-5zm0 2.236L15 8v8H5V8l5-3.764z"/>
          </svg>
        </div>
        <span class="text-base font-semibold text-charcoal">Meeqat</span>
      </div>
      <button type="button" onclick="closeMobileMenu()" class="p-2 rounded-lg text-muted hover:text-charcoal hover:bg-cream-100 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Masjid info (shown when available) -->
    <% if (typeof masjid !== 'undefined' && masjid) { %>
      <div class="px-5 py-4 border-b border-cream-100">
        <% if (masjid.image_url) { %>
          <div class="mb-3 rounded-xl overflow-hidden aspect-video">
            <img src="<%= masjid.image_url %>" alt="<%= masjid.name %>" class="w-full h-full object-cover">
          </div>
        <% } %>
        <h3 class="text-sm font-semibold text-charcoal truncate"><%= masjid.name %></h3>
        <p class="text-xs text-muted truncate"><%= masjid.city %>, <%= masjid.state %></p>
      </div>
    <% } %>

    <!-- Navigation links -->
    <nav class="flex-1 overflow-y-auto px-3 py-3 space-y-1">
      <a href="/admin" class="mobile-nav-link flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-muted hover:text-charcoal hover:bg-cream-50 transition-all active:bg-cream-100">
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Dashboard
      </a>
      <% if (typeof masjid !== 'undefined' && masjid) { %>
        <a href="/admin/edit" class="mobile-nav-link flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-muted hover:text-charcoal hover:bg-cream-50 transition-all active:bg-cream-100">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          Edit Details
        </a>
        <a href="/admin/timings" class="mobile-nav-link flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-muted hover:text-charcoal hover:bg-cream-50 transition-all active:bg-cream-100">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Prayer Times
        </a>
        <a href="/admin/jumuah" class="mobile-nav-link flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-muted hover:text-charcoal hover:bg-cream-50 transition-all active:bg-cream-100">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          Jumu'ah
        </a>
        <a href="/admin/announcements" class="mobile-nav-link flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-muted hover:text-charcoal hover:bg-cream-50 transition-all active:bg-cream-100">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/></svg>
          Announcements
        </a>
        <div class="h-px bg-cream-200 my-2 mx-2"></div>
        <a href="/admin/api-settings" class="mobile-nav-link flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-muted hover:text-charcoal hover:bg-cream-50 transition-all active:bg-cream-100">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          API Settings
        </a>
      <% } %>
    </nav>

    <!-- Footer -->
    <div class="px-5 py-4 border-t border-cream-100 shrink-0">
      <% if (typeof adminEmail !== 'undefined' && adminEmail) { %>
        <p class="text-xs text-muted truncate mb-2"><%= adminEmail %></p>
      <% } %>
      <a href="/admin/logout" class="flex items-center gap-2 text-sm text-muted hover:text-charcoal transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        Logout
      </a>
    </div>
  </div>
</aside>

<script>
function toggleMobileMenu() {
  const overlay = document.getElementById('mobile-menu-overlay');
  const drawer = document.getElementById('mobile-menu-drawer');
  const isOpen = !overlay.classList.contains('hidden');
  if (isOpen) {
    closeMobileMenu();
  } else {
    overlay.classList.remove('hidden');
    requestAnimationFrame(() => {
      drawer.style.transform = 'translateX(0)';
    });
    document.body.style.overflow = 'hidden';
  }
}

function closeMobileMenu() {
  const overlay = document.getElementById('mobile-menu-overlay');
  const drawer = document.getElementById('mobile-menu-drawer');
  drawer.style.transform = 'translateX(-100%)';
  setTimeout(() => {
    overlay.classList.add('hidden');
  }, 300);
  document.body.style.overflow = '';
}

// Highlight current page in mobile nav
document.addEventListener('DOMContentLoaded', function() {
  const path = window.location.pathname;
  document.querySelectorAll('.mobile-nav-link').forEach(function(link) {
    const href = link.getAttribute('href');
    if (href === path || (href !== '/admin' && path.startsWith(href))) {
      link.classList.remove('text-muted');
      link.classList.add('text-charcoal', 'bg-cream-50', 'font-semibold');
    }
  });
  // Also highlight sidebar links
  document.querySelectorAll('.sidebar-link').forEach(function(link) {
    const href = link.getAttribute('href');
    if (href === path || (href !== '/admin' && path.startsWith(href))) {
      link.classList.remove('text-muted');
      link.classList.add('text-charcoal', 'bg-cream-50', 'font-semibold');
    }
  });
});
</script>
