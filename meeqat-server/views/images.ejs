<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-6 gap-4">
    <div>
      <a href="/admin" class="inline-flex items-center gap-1 text-muted text-sm hover:text-charcoal transition-colors mb-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Dashboard
      </a>
      <h1 class="text-2xl font-semibold text-charcoal">Media Library</h1>
      <p class="text-muted text-sm mt-1">Upload and manage images for your masjids and announcements</p>
    </div>
    <div class="flex bg-cream-100 rounded-xl p-1 gap-0.5">
      <a href="/admin/images" class="text-xs font-medium px-3 py-1.5 rounded-lg transition-colors <%= filter === 'all' ? 'bg-white text-charcoal shadow-sm' : 'text-muted hover:text-charcoal' %>">All</a>
      <a href="/admin/images?filter=masjids" class="text-xs font-medium px-3 py-1.5 rounded-lg transition-colors <%= filter === 'masjids' ? 'bg-white text-charcoal shadow-sm' : 'text-muted hover:text-charcoal' %>">Masjids</a>
      <a href="/admin/images?filter=announcements" class="text-xs font-medium px-3 py-1.5 rounded-lg transition-colors <%= filter === 'announcements' ? 'bg-white text-charcoal shadow-sm' : 'text-muted hover:text-charcoal' %>">Announcements</a>
      <a href="/admin/images?filter=gallery" class="text-xs font-medium px-3 py-1.5 rounded-lg transition-colors <%= filter === 'gallery' ? 'bg-white text-charcoal shadow-sm' : 'text-muted hover:text-charcoal' %>">Gallery</a>
    </div>
  </div>

  <!-- How it works -->
  <div class="bg-duck-400/5 border border-duck-400/20 rounded-xl px-5 py-4 mb-6">
    <h3 class="text-sm font-semibold text-duck-600 mb-2">How images work</h3>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-xs text-duck-600">
      <div class="flex items-start gap-2">
        <span class="w-5 h-5 rounded-full bg-duck-400/15 flex items-center justify-center shrink-0 mt-0.5 text-[10px] font-bold">1</span>
        <span><strong>Upload</strong> images here or directly when editing a masjid / creating an announcement.</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="w-5 h-5 rounded-full bg-duck-400/15 flex items-center justify-center shrink-0 mt-0.5 text-[10px] font-bold">2</span>
        <span>Images are stored in <strong>Firebase Storage</strong> and served via Google Cloud CDN.</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="w-5 h-5 rounded-full bg-duck-400/15 flex items-center justify-center shrink-0 mt-0.5 text-[10px] font-bold">3</span>
        <span>The <strong>Flutter app</strong> automatically displays them in announcements and masjid profiles.</span>
      </div>
    </div>
  </div>

  <!-- Upload Area -->
  <div class="bg-white rounded-2xl shadow-sm border border-cream-200 p-5 mb-8">
    <form method="POST" action="/admin/images/upload" enctype="multipart/form-data" id="upload-form">
      <div id="drop-zone"
        class="border-2 border-dashed border-cream-200 rounded-2xl p-8 text-center hover:border-gold-400 hover:bg-gold-400/5 transition-all cursor-pointer"
        ondragover="event.preventDefault(); this.classList.add('border-gold-400', 'bg-gold-400/5')"
        ondragleave="this.classList.remove('border-gold-400', 'bg-gold-400/5')"
        ondrop="event.preventDefault(); this.classList.remove('border-gold-400', 'bg-gold-400/5'); document.getElementById('file-input').files = event.dataTransfer.files; handleFiles();">
        <div class="w-14 h-14 bg-cream-100 rounded-2xl flex items-center justify-center mx-auto mb-3">
          <svg class="w-7 h-7 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <p class="text-sm font-medium text-charcoal mb-1">Drop images here or click to upload</p>
        <p class="text-xs text-muted">PNG, JPG, WebP up to 20MB each &middot; Max 10 at once</p>
        <input type="file" name="images" id="file-input" accept="image/*" multiple class="hidden" onchange="handleFiles()">
        <div id="file-preview" class="hidden mt-4 flex flex-wrap gap-3 justify-center"></div>
      </div>

      <div id="upload-actions" class="hidden mt-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <label class="text-xs font-medium text-muted uppercase tracking-wider">Save to:</label>
          <select name="folder" class="text-sm px-3 py-1.5 rounded-lg border border-cream-200 bg-cream-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-gold-400">
            <option value="gallery">General Gallery</option>
            <option value="masjids">Masjid Photos</option>
            <option value="announcements">Announcement Images</option>
          </select>
        </div>
        <div class="flex gap-2">
          <button type="button" onclick="clearFiles()" class="text-sm px-4 py-2 rounded-xl text-muted hover:bg-cream-100 transition-colors">Cancel</button>
          <button type="submit" class="text-sm font-medium bg-gradient-to-r from-gold-400 to-gold-500 text-white px-6 py-2 rounded-xl hover:from-gold-500 hover:to-gold-600 transition-all shadow-sm active:scale-[0.98]">
            Upload
          </button>
        </div>
      </div>
    </form>
  </div>

  <!-- Image Grid -->
  <% if (images.length === 0) { %>
    <div class="bg-white rounded-2xl shadow-sm border border-cream-200 p-16 text-center">
      <div class="w-20 h-20 bg-cream-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
        <svg class="w-10 h-10 text-cream-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
      <h3 class="text-lg font-medium text-charcoal mb-1">No images yet</h3>
      <p class="text-muted text-sm max-w-sm mx-auto">Upload images above. They'll appear in the Flutter app when attached to announcements or masjid profiles.</p>
    </div>
  <% } else { %>
    <div class="flex items-center justify-between mb-4">
      <p class="text-sm text-muted"><%= images.length %> image<%= images.length !== 1 ? 's' : '' %></p>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
      <% images.forEach(function(img) { %>
        <div class="group relative bg-white rounded-2xl shadow-sm border border-cream-200 overflow-hidden hover:shadow-md transition-all">
          <div class="aspect-square overflow-hidden bg-cream-50 cursor-pointer" onclick="openLightbox('<%= img.url %>')">
            <img src="<%= img.url %>" alt="<%= img.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy">
          </div>
          <div class="p-3">
            <p class="text-xs font-medium text-charcoal truncate" title="<%= img.name %>"><%= img.name %></p>
            <div class="flex items-center justify-between mt-1.5">
              <span class="inline-flex items-center px-2 py-0.5 rounded-md text-[10px] font-medium
                <%= img.folder === 'masjids' ? 'bg-duck-400/10 text-duck-500' : img.folder === 'announcements' ? 'bg-sage-400/10 text-sage-500' : 'bg-gold-400/10 text-gold-500' %>">
                <%= img.folder %>
              </span>
              <% if (img.inUse) { %>
                <span class="flex items-center gap-1 text-[10px] text-sage-500 font-medium">
                  <span class="w-1.5 h-1.5 rounded-full bg-sage-400"></span>
                  In use
                </span>
              <% } %>
            </div>
          </div>
          <!-- Hover Actions -->
          <div class="absolute top-2 right-2 flex gap-1.5 opacity-0 group-hover:opacity-100 transition-opacity">
            <button onclick="copyUrl('<%= img.url %>')" title="Copy URL"
              class="w-8 h-8 bg-white/90 backdrop-blur-sm rounded-lg flex items-center justify-center shadow-sm hover:bg-white transition-colors">
              <svg class="w-4 h-4 text-charcoal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
            </button>
            <form method="POST" action="/admin/images/<%= encodeURIComponent(img.path) %>/delete" onsubmit="return confirm('Delete this image?<%= img.inUse ? ' Warning: it is currently used by a masjid or announcement.' : '' %>')">
              <button type="submit" title="Delete"
                class="w-8 h-8 bg-white/90 backdrop-blur-sm rounded-lg flex items-center justify-center shadow-sm hover:bg-red-50 transition-colors">
                <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</main>

<!-- Lightbox Modal -->
<div id="lightbox" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-[200] hidden items-center justify-center p-4 cursor-pointer" onclick="closeLightbox()">
  <button onclick="closeLightbox()" class="absolute top-4 right-4 w-10 h-10 bg-white/10 rounded-full flex items-center justify-center hover:bg-white/20 transition-colors">
    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>
  <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[90vh] rounded-2xl shadow-2xl object-contain" onclick="event.stopPropagation()">
</div>

<!-- Copy URL toast -->
<div id="copy-toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-[200] hidden">
  <div class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-charcoal text-white text-sm font-medium shadow-lg">
    <svg class="w-4 h-4 text-sage-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
    URL copied to clipboard
  </div>
</div>

<script>
  document.getElementById('drop-zone').addEventListener('click', () => {
    document.getElementById('file-input').click();
  });

  function handleFiles() {
    const input = document.getElementById('file-input');
    const preview = document.getElementById('file-preview');
    const actions = document.getElementById('upload-actions');

    if (input.files.length > 0) {
      preview.innerHTML = '';
      preview.classList.remove('hidden');
      actions.classList.remove('hidden');

      Array.from(input.files).forEach(file => {
        const reader = new FileReader();
        reader.onload = (e) => {
          const div = document.createElement('div');
          div.className = 'w-16 h-16 rounded-xl overflow-hidden border border-cream-200 shadow-sm';
          div.innerHTML = '<img src="' + e.target.result + '" class="w-full h-full object-cover">';
          preview.appendChild(div);
        };
        reader.readAsDataURL(file);
      });
    }
  }

  function clearFiles() {
    document.getElementById('file-input').value = '';
    document.getElementById('file-preview').innerHTML = '';
    document.getElementById('file-preview').classList.add('hidden');
    document.getElementById('upload-actions').classList.add('hidden');
  }

  function openLightbox(url) {
    const lb = document.getElementById('lightbox');
    document.getElementById('lightbox-img').src = url;
    lb.classList.remove('hidden');
    lb.classList.add('flex');
  }

  function closeLightbox() {
    const lb = document.getElementById('lightbox');
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    document.getElementById('lightbox-img').src = '';
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });

  async function copyUrl(url) {
    try {
      await navigator.clipboard.writeText(url);
      const toast = document.getElementById('copy-toast');
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), 2000);
    } catch {
      prompt('Copy this URL:', url);
    }
  }
</script>
</body>
</html>
